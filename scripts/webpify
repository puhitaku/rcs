#done

# Check if GNU Parallel is installed
if ! command -v parallel > /dev/null; then
    echo "Error: GNU Parallel is not installed."
    exit 1
fi

# Define the conversion function and export it for parallel
convert_webp() {
    local input="$1"
    local filename=$(basename "${input}")
    local output="${filename%.*}.webp"

    # Run ImageMagick
    magick -define webp:method=6 -quality 90 "$input" "$output"
}
export -f convert_webp

# Run parallel
# --bar: Display a progress bar
# -j: Use $(nproc) jobs by default, or specify e.g., -j+0
# --plus: Enhanced replacement strings (optional, but useful)
parallel --bar convert_webp ::: "$@"
