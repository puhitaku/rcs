sudo yabai --load-sa
yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa"

config=(
    window_origin_display        default
    window_placement             second_child
    window_shadow                float
    split_ratio                  0.50
    split_type                   vertical
    auto_balance                 on
    mouse_modifier               fn
    mouse_action1                move
    mouse_action2                resize
    mouse_drop_action            swap
    top_padding                  8
    bottom_padding               8
    left_padding                 8
    right_padding                8
    window_gap                   8
    layout                       bsp
)

yabai -m config $(echo ${config[*]} | tr '=' ' ')
yabai -m rule --add app=".*" manage=off
yabai -m rule --apply

# Show the current space with SwiftBar
yabai -m signal --add event=space_changed action='yabaiutil sb-yabai-spaces'

# Focus the first window after switching a space
# Ref: https://github.com/koekeishiya/yabai/issues/719
yabai -m signal --add event=space_changed action="sleep 0.1 && yabai -m window --focus \$(yabai -m query --windows --space | jq .[0].id)"

borders active_color=0xffffccd1 inactive_color=0x00000000 width=6.0 style=round blacklist='Autodesk Fusion' &
echo "yabai configuration loaded.."
